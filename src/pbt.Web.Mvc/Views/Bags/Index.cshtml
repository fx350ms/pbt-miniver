@using pbt.Web.Startup
@using pbt.Authorization
@using pbt.ApplicationUtils
@using pbt.Web.Models.Common.Modals

@model pbt.Web.Models.Bags.BagIndexViewModel

@{
    ViewBag.Title = L("Bags");
    ViewBag.CurrentPageName = PageNames.Packages;
}
@section scripts
{
    @if (PermissionChecker.IsGranted(PermissionNames.Function_BagDelete))
    {
        <script>
            var hasRoleDeleteBag = true;
        </script>
    }
    else
    {
        <script>
            var hasRoleDeleteBag = false;
        </script>
    }
    <environment names="Development">
        <script src="~/view-resources/Views/Bags/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Bags/Index.min.js" asp-append-version="true"></script>
    </environment>

}
@section styles{
    <style>
        .select2-container--bootstrap4 .select2-selection__clear {
            float: right;
            width: .9em;
            height: .9em;
            padding-left: .15em;
            margin-top: .7em;
            margin-right: .3em;
            line-height: .75em;
            color: #f8f9fa;
            background-color: #dc3545 !important;
            border-radius: 100%
        }
        
    </style>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("Bags")</h1>
            </div>
            <div class="col-sm-6 text-right">
                <button type="button" class="btn btn-default">@L("UpdateShippingPartner")</button>
                <button type="button" class="btn btn-primary btn-export-excel">
                    <i class="fas fa-file-excel"></i> @L("ExportExcel")
                </button>
                <button type="button" class="btn btn-primary btn-export-bag-detail">
                    <i class="fas fa-file-excel"></i> @L("ExportBagDetail")
                </button>
                <div class="btn-group">
                    <button type="button" class="btn btn-success btn-export-manifest">
                        <i class="fas fa-download"></i>  @L("ExportManifest")
                    </button>
                    <button type="button" class="btn btn-success dropdown-toggle" data-toggle="dropdown" aria-expanded="false">
                        <span class="sr-only"></span>
                    </button>
                    <div class="dropdown-menu" role="menu" style="">
                        <button type="button" class="btn btn-success btn-export-manifest-en">
                            <i class="famfamfam-flags gb" title=" @L("ExportManifestEn")"></i>  @L("ExportManifestEn")
                        </button>
                    </div>
                </div>

            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item">
                        <a class="nav-link nav-bag active" data-type="all" href="#">@L("AllBags")</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-bag" data-type="today" href="#">@L("BagsCreatedToday")</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        @await Html.PartialAsync("~/Views/Bags/Index.AdvancedSearch.cshtml", Model)
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <div class="table-header"> <b id="totalBag"></b> @L("Bag") | <b id="totalWeight"></b>(kg)</div>
                            <table id="DepartmentsTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>@L("BagCode")</th>
                                        <th>@L("Receiver")</th>
                                        <th>@L("TotalPackage")</th>
                                        <th>@L("TotalWeightKG")</th>
                                        <th>@L("BagType")</th>
                                        <th>@L("CustomerName")</th>
                                        <th>@L("DateCreate")</th>
                                        <th>@L("WarehouseCreate")</th>
                                        <th>@L("WarehouseDestination")</th>
                                        <th>@L("ShippingLine")</th>
                                        <th>@L("ShippingStatus")</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<div class="modal fade" id="WarehouseTransfer" tabindex="-1" role="dialog" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            @await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("CreateWarehouseTransfer")))
            <div class="form-horizontal">
                <div class="modal-body">
                    <form name="warehouseTransferForm" role="form" class="form-horizontal">
                        <input type="hidden" name="BagId" />
                        <div class="form-group row required">
                            <label class="col-md-3 col-form-label">@L("SelectNewWarehouse")</label>
                            <div class="col-md-4">
                                <select class="form-control" name="ToWarehouse" placeholder="Chọn kho mới">
                                    @if (Model.WarehousesVN != null)
                                    {
                                        foreach (var warehouse in Model.WarehousesVN)
                                        {
                                            <option value="@warehouse.Id">@warehouse.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-md-3 col-form-label">@L("Note")</label>
                            <div class="col-md-9">
                                <textarea type="text" name="Note" class="form-control"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer justify-content-between">
                            <button type="button" class="btn btn-default close-button" data-dismiss="modal">Hủy</button>
                            <button type="button" class="btn btn-primary btn-save-bag-warehouse-transfer">
                                <i class="fa fa-save"></i> Lưu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>