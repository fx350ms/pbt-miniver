@using pbt.Web.Models.Common.Modals
@using pbt.Web.Startup
@using pbt.Customers.Dto
@using pbt.ApplicationUtils
@using pbt.Orders.Dto
@using pbt.Web.Models.Orders
@using pbt
@using pbt.Authorization
@using pbt.CustomerAddresss.Dto
@using pbt.Waybills.Dto

@model CreateMyOrderModel

@{
    ViewBag.Title = L("CreateMyOrder");
    ViewBag.CurrentPageName = PageNames.Orders;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/Orders/CreateMyOrder.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Orders/CreateMyOrder.min.js" asp-append-version="true"></script>
    </environment>

}
@section styles {
    <style>
        .select2-selection--single {
            height: 38px !important;
        }

        .select2-selection__arrow {
            top: 5px !important;
        }
    </style>
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("CreateMyOrder"): <strong class="text-primary">@Model.Dto.OrderNumber</strong> </h1>
            </div>
            <div class="col-sm-6">
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">

                    <div class="card-body">
                        @if (Model != null)
                        {
                            <form id="form-create-my-order" role="form" class="form-horizontal">
                                <input type="hidden" id="hiddenCustomerId" name="CustomerId" value="@User.Claims.Get("CustomerId")" />
                                <input type="hidden" name="CustomerName" value="@User.Identity.Name" />
                                <input type="hidden" name="IsCustomerOrder" value="false" />
                                <input type="hidden" name="OrderNumber" value="@Model.Dto.OrderNumber" />
                                <input type="hidden" id="UseInsurance" name="UseInsurance" value="false" />
                                <input type="hidden" id="UseDomesticTransportation" name="UseDomesticTransportation" value="false" />
                                <input type="hidden" id="UseShockproofPackaging" name="UseShockproofPackaging" value="false" />
                                <input type="hidden" id="UseWoodenPackaging" name="UseWoodenPackaging" value="false" />
                                <div class="modal-body">
                                    <div class="form-group row">
                                        <div class="col-md-6">
                                            <div class="row form-group">
                                                <div class="col-md-6">
                                                    @* <input type="text" readonly class="form-control" name="WaybillNumber" asp-for="Dto.WaybillNumber" placeholder="@L("InputWaybillNumber")" required> *@
                                                    <select class="select2 select2-hidden-accessible " name="WaybillNumber" asp-for="Dto.WaybillNumber" style="width: 100%;">
                                                        @if (!string.IsNullOrEmpty(Model.WaybillCode))
                                                        {
                                                            <option value="@Model.WaybillCode" selected> @Model.WaybillCode</option>
                                                        }
                                                    </select>
                                                    <span asp-validation-for="Dto.WaybillNumber" class="text-danger"></span>

                                                </div>
                                                <div class="col-md-6">
                                                    <button type="button" class="btn btn-primary " data-toggle="modal" data-target="#WaybillCreateModal">@L("CreateNewWaybill")</button>
                                                </div>
                                            </div>
                                            <div class="row form-group">
                                                <div class="col-md-6">
                                                    <select class="form-control" name="ShippingLine" asp-for="Dto.ShippingLine" required>
                                                        <option value="@((int)CustomerLine.Line1)" selected>@CustomerLine.Line1.GetDescription()</option>
                                                        <option value="@((int)CustomerLine.Line2)">@CustomerLine.Line2.GetDescription()</option>
                                                        <option value="@((int)CustomerLine.OfficialTransport)">@CustomerLine.OfficialTransport.GetDescription()</option>
                                                    </select>
                                                    <span asp-validation-for="Dto.ShippingLine" class="text-danger"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-1 d-flex justify-content-end">
                                            <div class="form-group row">
                                                <label>@L("Service")</label>
                                            </div>
                                        </div>

                                        <div class="col-md-5">

                                            <div class="row">
                                                <div class="col-4">
                                                    <div class="custom-control custom-checkbox">
                                                        <input class="custom-control-input" data-service-target="#UseInsurance" name="OnUseInsurance" type="checkbox" id="select-insurance">
                                                        <label class="custom-control-label" for="select-insurance">@L("Insurance")</label>
                                                    </div>
                                                </div>
                                                <div class="col-8">
                                                    <div class="custom-control custom-checkbox">
                                                        <input class="form-control" id="inputInsurance" name="PriceInsurance" placeholder="Giá trị hàng hóa" value="0">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-4">
                                                    <div class="custom-control custom-checkbox">
                                                        <input class="custom-control-input" data-service-target="#UseWoodenPackaging" name="OnUseWoodenPackaging" type="checkbox" id="select-wooden-packaging">
                                                        <label class="custom-control-label" for="select-wooden-packaging">@L("WoodenPackaging")</label>
                                                    </div>
                                                </div>

                                            </div>
                                            <div class="row">
                                                <div class="col-4">
                                                    <div class="custom-control custom-checkbox">
                                                        <input class="custom-control-input" data-service-target="#UseShockproofPackaging" name="OnUseShockproofPackaging" type="checkbox" id="select-shockproof-packaging">
                                                        <label class="custom-control-label" for="select-shockproof-packaging">@L("ShockproofPackaging")</label>
                                                    </div>
                                                </div>

                                            </div>
                                            <div class="row">
                                                <div class="col-4">
                                                    <div class="custom-control custom-checkbox">
                                                        <input class="custom-control-input" data-service-target="#UseDomesticTransportation" name="OnUseDomesticTransportation" type="checkbox" id="select-domestic-transportation">
                                                        <label class="custom-control-label" for="select-domestic-transportation">@L("DomesticTransportation")</label>
                                                    </div>
                                                </div>

                                            </div>

                                        </div>

                                    </div>
                                    <hr />

                                    <div class="form-group row">
                                        <div class="col-md-6">
                                            <h4>@L("SelectReceivingWarehouseChina")</h4>
                                            <input type="hidden" name="CNWarehouseId" id="CNWarehouseId" value="@Model.Dto.CNWarehouseId" asp-for="Dto.CNWarehouseId" required />

                                            @await Html.PartialAsync("~/Views/Orders/_WarehousesChina.cshtml", Model.WarehousesChina)

                                        </div>
                                        <div class="col-md-6">
                                            <h4>@L("SelectReceivingWarehouseVietnam")</h4>

                                            <input type="hidden" name="VNWarehouseId" id="VNWarehouseId" value="@Model.Dto.VNWarehouseId" asp-for="Dto.VNWarehouseId" required />
                                            @await Html.PartialAsync("~/Views/Orders/_WarehousesVietNam.cshtml", Model.WarehousesVietNam)
                                            <div class="row form-group">
                                                <div class="col-4">
                                                    <h4>@L("AddressReceiver")</h4>
                                                </div>
                                                <div class="col-4">
                                                    <a href="javascript:;" data-toggle="modal" data-target="#CustomerAddressCreateModal" class="btn bg-blue btn-add-new-address">
                                                        <i class="fa fa-plus-square"></i>
                                                        @L("AddNewAddress")
                                                    </a>
                                                </div>
                                            </div>
                                            <input type="hidden" name="AddressId" id="AddressId" value="@Model.Dto.AddressId" asp-for="Dto.AddressId" required />
                                            <div id="address-box">
                                                @if (Model != null && Model.Addresses != null && Model.Addresses.Count > 0)
                                                {
                                                    foreach (var item in Model.Addresses)
                                                    {
                                                        <div class="card">
                                                            <div class="card-header">
                                                                <input type="radio" id="rd-address-@item.Id" name="address" data-target="address-@item.Id" value="@item.Id" target="AddressId">
                                                                <label class="control-label" for="rd-address-@item.Id">@item.FullName - @item.PhoneNumber</label>
                                                            </div>
                                                            <div class="card-body" id="address-@item.Id" data-type="address-id">
                                                                <div class="form-group">
                                                                    <label>Địa chỉ </label>
                                                                    <p>@item.FullAddress </p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer justify-content-between">
                                    <button type="button" class="btn btn-default close-button" data-dismiss="modal">@L("Cancel")</button>
                                    <button type="submit" class="btn btn-primary save-button">@L("CreateOrder")</button>
                                </div>

                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


@await Html.PartialAsync("~/Views/Orders/_CreateAddressModal.cshtml", new CustomerAddressDto() { })
@await Html.PartialAsync("~/Views/Orders/_CreateWaybillModal.cshtml", new CreateWaybillSimpleDto() { }) 