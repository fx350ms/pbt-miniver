@using pbt.Web.Models.Orders

@model OrderDetailModel

<div class="modal fade" id="editInsuranceModal" tabindex="-1" role="dialog" aria-labelledby="editInsuranceModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editInsuranceModalLabel">Sửa bảo hiểm</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="editInsuranceForm">
                <input type="hidden" name="id" id="id" value="@Model.PackageDto.Id">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="insuranceValue">Loại tền tệ</label>
                        <select class="form-control" id="insuranceType" name="insuranceType">
                            <option value="vnd">Việt Nam Đồng</option>
                            <option value="rmb">RMB</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="insuranceValue">Giá trị hàng hóa cần bảo hiểm</label>
                        <input type="number" class="form-control" id="insuranceValue" name="insuranceValue" required/>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@L("Cancel")</button>
                    <button type="submit" class="btn btn-primary">@L("Save")</button>
                </div>
            </form>
        </div>
    </div>
</div>