@using pbt.Web.Startup
@using pbt.Web.Models.Operate
@model ScanCodeHistoryViewModel
@{
    ViewBag.Title = L("Pages_Packages_Pending");
    ViewBag.CurrentPageName = PageNames.Packages;
}


@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/Operate/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Operate/Index.min.js" asp-append-version="true"></script>
    </environment>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("ScanCodeHistory")</h1>
            </div>
            <div class="col-sm-6 text-right">
                <button type="button" class="btn btn-success btn-export">@L("ExportExcel")</button>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        @await Html.PartialAsync("~/Views/Operate/Index.AdvancedSearch.cshtml", Model )
                    </div>
                   
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="CodeTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>STT</th>
                                        <th>@L("ScanCode")</th>
                                        <th>@L("CustomerName")</th>
                                        <th>@L("ScanDateTime")</th>
                                        <th>@L("CodeType")</th>
                                        <th>@L("Action")</th>
                                        <th>@L("WarehouseScan")</th>
                                        <th>@L("ScanUser")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
