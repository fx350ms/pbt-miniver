@using pbt.Web.Startup

@{
    ViewBag.Title = L("Operate");
    ViewBag.CurrentPageName = PageNames.Operate;
}

@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/Operate/Scan.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Operate/Scan.min.js" asp-append-version="true"></script>
    </environment>
}

@section styles
{
    <style>
        .operate-data {
            min-height: calc(100vh - 160px);
        }

        .barcode-placeholder {
            text-align: center;
            color: #6c757d;
        }

            .barcode-placeholder img {
                max-width: 150px;
                margin-bottom: 10px;
            }

        .btn-group-toggle .btn {
            width: 48%;
        }

        .operate-input {
            min-height: calc(100vh - 160px);
        }
    </style>
}

<section class="content-header">
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3">
                <form id="form-scan-code" role="form" class="form-horizontal" onsubmit="return false;">
                    <input type="hidden" id="CodeType" name="CodeType" />

                    <input type="hidden" id="SourceWarehouseId" name="SourceWarehouseId" />
                    <input type="hidden" id="DestinationWarehouseId" name="DestinationWarehouseId" />
                    <div class="card">
                        <div class="card-body operate-input">
                            <h5>Hành động</h5>
                            <div class="btn-group btn-group-toggle mb-4" data-toggle="buttons" style="width: 150px">
                                <label class="btn btn-outline-primary active">
                                    <input type="radio" name="action" autocomplete="off" checked> Nhập
                                </label>
                                <label class="btn btn-outline-primary ml-2">
                                    <input type="radio" name="action" autocomplete="off"> Xuất
                                </label>
                            </div>

                            <h5>Kho</h5>
                            <div class="btn-group btn-group-toggle mb-4" data-toggle="buttons" style="width: 150px">
                                <label class="btn btn-outline-primary active">
                                    <input type="radio" name="warehouse" autocomplete="off" checked> TQ
                                </label>
                                <label class="btn btn-outline-primary ml-2">
                                    <input type="radio" name="warehouse" autocomplete="off"> HN
                                </label>
                            </div>

                            <h5>Quét mã</h5>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="CodeType" value="" id="bao">
                                <label class="form-check-label" for="bao">
                                    Bao
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="CodeType" value="" id="kien">
                                <label class="form-check-label" for="kien">
                                    Kiện
                                </label>
                            </div>
                            <input type="text" id="txtInputCodeScan" class="form-control" placeholder="Nhập mã...">
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-md-9">
                @* <div class="card"> *@
                @*     <div class="card-body operate-data"> *@
                @*         <div class="barcode-placeholder"> *@
                @*             <i class="fa fa-barcode fa-6" style="font-size: 12em"></i> *@
                @*             <p>Chưa có dữ liệu quét mã</p> *@
                @*         </div> *@
                @*     </div> *@
                @* </div> *@
                <div class="card">
                    <div class="card-header">
                        <h4>@L("BarcodeTable")</h4>
                        @await Html.PartialAsync("~/Views/Operate/Create.AdvancedSearch.cshtml")
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="BarcodeTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>@L("ScanCode")</th>
                                        <th>@L("ScanDateTime")</th>
                                        <th>@L("CodeType")</th>
                                        <th>@L("Action")</th>
                                        <th>@L("WarehouseScan")</th>
                                        <th>@L("ScanUser")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
