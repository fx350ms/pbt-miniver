@using pbt.ApplicationUtils
@using pbt.Authorization.Users
@using pbt.Web.Startup
@using pbt.Authorization

@{
    ViewBag.Title = L("Operate");
    //   ViewBag.CurrentPageName = PageNames.Operate;

    var warehouseType = ViewBag.warehouseType;
}

@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/Operate/Create.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Operate/Create.min.js" asp-append-version="true"></script>
    </environment>
}

@section styles
{
    <style>
        .operate-data {
            min-height: calc(100vh - 160px);
        }

        .barcode-placeholder {
            text-align: center;
            color: #6c757d;
        }

            .barcode-placeholder img {
                max-width: 150px;
                margin-bottom: 10px;
            }

        .btn-group-toggle .btn {
            width: 48%;
        }

        .operate-input {
            min-height: calc(100vh - 160px);
        }

        .btn-option {
            min-width: 107px;
        }
    </style>
}

<section class="content-header">
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3">
                <form id="form-scan-code" role="form" class="form-horizontal" onsubmit="return false;">

                    <div class="card">
                        <div class="card-body operate-input">
                            <h5>@L("Action")</h5>
                            <div class="btn-group btn-group-toggle mb-4" data-toggle="buttons" style="width: 150px">
                                <label class="btn btn-outline-primary btn-option active">
                                    <input type="radio" name="actionType" value="@((int)OperateActionType.In)" checked> @L("In")
                                </label>
                                <label class="btn btn-outline-primary btn-option">
                                    <input type="radio" name="actionType" value="@((int)OperateActionType.Out)"> @L("Out")
                                </label>
                            </div>

                            <h5>@L("Warehouse")</h5>

                            <div class="btn-group btn-group-toggle mb-4" data-toggle="buttons" style="width: 150px">
                                @if (warehouseType == (int)WarehouseType.Cn)
                                {
                                    <label class="btn btn-outline-primary btn-option active">
                                        <input type="radio" name="Warehouse" value="@((int)WarehouseType.Cn)" id="option1" autocomplete="off" checked> @L("China")
                                    </label>
                                }
                                @if (warehouseType == (int)WarehouseType.Vn)
                                {
                                    <label class="btn btn-outline-primary btn-option">
                                        <input type="radio" name="Warehouse" value="@((int)WarehouseType.Vn)" id="option2" autocomplete="off" checked> @L("HaNoi")
                                    </label>
                                }

                            </div>
                            <h5>@L("CodeType")</h5>
                            <div class="btn-group btn-group-toggle mb-4" data-toggle="buttons" style="width: 250px">
                                <label class="btn btn-outline-primary btn-option active">
                                    <input type="radio" name="CodeType" value="@((int)CodeType.Bag)" id="option-CodeType-Bag" autocomplete="off" checked> @L("Bag")
                                </label>
                                @if (warehouseType == (int)WarehouseType.Vn)
                                {
                                    <label class="btn btn-outline-primary btn-option">
                                        <input type="radio" name="CodeType" value="@((int)CodeType.Package)" id="option-CodeType-Package" autocomplete="off"> @L("Package")
                                    </label>
                                }
                                @if (warehouseType == (int)WarehouseType.Cn)
                                {
                                    <label class="btn btn-outline-primary btn-option">
                                        <input type="radio" name="CodeType" value="@((int)CodeType.Waybill)" id="option-CodeType-Package" autocomplete="off"> @L("Waybill")
                                    </label>
                                }
                            </div>

                            <h5>@L("ScanCode")</h5>
                            <input type="text" id="txtInputCodeScan" name="ScanCode" class="form-control" placeholder="@L("InputCode")...">
                            <div class="row-group" style="margin-top:20px">
                                <strong> <p class="text-danger" id="txt-order-note" style="font-size:20px;"></p></strong>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-md-9">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-6">
                                <h4>@L("BarcodeTable")</h4>
                            </div>

                        </div>
                    </div>
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-2 ">
                                <h4>@L("TotalCode"): <strong id="totalRecords" class="text-info"></strong>  </h4>
                            </div>

                            <div class="col-md-2">
                                @if (PermissionChecker.IsGranted(PermissionNames.Function_ScanCodeViewAll))
                                {
                                    <div class="d-flex align-items-center">

                                        <label for="OnlyCurrentUser" style="font-weight: normal" class="ml-2">
                                            <input id="OnlyCurrentUser" type="checkbox" checked="checked" />   @L("OnlyMyCode")
                                        </label>
                                    </div>
                                }
                                <input type="hidden" id="hiddenMyCode" name="OnlyMyCode" value="true" />

                            </div>

                            <div class="col-md-8">
                                <button class="btn bg-danger float-sm-right btn-delete-all" style="margin-right:10px">
                                    <i class="fa fa-trash"></i>
                                    @L("DeleteAll")
                                </button>
                                <button class="btn bg-danger float-sm-right btn-delete" style="margin-right:10px" disabled>
                                    <i class="fa fa-times"></i>
                                    @L("Delete")
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="BarcodeTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th><input type="checkbox" data-check="all" /></th>
                                        <th>STT</th>
                                        <th>@L("ScanCode")</th>
                                        <th>@L("CustomerName")</th>
                                        <th>@L("OrderNote")</th>
                                        <th>@L("ScanDateTime")</th>
                                        <th>@L("CodeType")</th>
                                        <th>@L("Action")</th>
                                        <th>@L("ScanUser")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
