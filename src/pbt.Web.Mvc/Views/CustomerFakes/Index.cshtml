@using pbt.Web.Startup
@using pbt.Web.Models.CustomerFakes
@using pbt.CustomerFakes.Dto;

@{
    ViewBag.Title = L("CustomerFakes");
    ViewBag.CurrentPageName = PageNames.CustomerFake;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/CustomerFakes/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/CustomerFakes/Index.min.js" asp-append-version="true"></script>
    </environment>
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("CustomerFake")</h1>
            </div>
            <div class="col-sm-6">
                <a href="javascript:;" data-toggle="modal" data-target="#CustomerFakeCreateModal" class="btn bg-blue float-sm-right">
                    <i class="fa fa-plus-square"></i>
                    @L("Create")
                </a>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-6">
                                <!--Use for bulk actions-->
                                <button></button>
                            </div>
                            <div class="col-md-6">
                                @await Html.PartialAsync("~/Views/CustomerFakes/Index.AdvancedSearch.cshtml")
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="CustomerFakesTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>@L("FullName")</th>
                                        <th>@L("Address")</th>
                                      
                                        <th style="width: 150px">@L("Actions")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/CustomerFakes/_CreateModal.cshtml", new CreateUpdateCustomerFakeDto() {  }) ;

<div class="modal fade" id="CustomerFakeEditModal" tabindex="-1" role="dialog" aria-labelledby="CustomerFakeEditModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>
