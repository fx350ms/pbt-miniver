@using pbt.Warehouses.Dto
@using pbt.Web.Models.Warehouses
@using pbt.Web.Startup

@{
    ViewBag.Title = L("WarehouseTransfers");
    ViewBag.CurrentPageName = L("WarehouseTransfers");
}

@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/WarehouseTransfers/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/WarehouseTransfers/Index.min.js" asp-append-version="true"></script>
    </environment>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("WarehouseTransfers")</h1>
            </div>
            <div class="col-sm-6">
                <a href="javascript:;" data-toggle="modal" data-target="#WarehouseTransferCreateModal" class="btn bg-blue float-sm-right">
                    <i class="fa fa-plus-square"></i>
                    @L("Create")
                </a>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        @await Html.PartialAsync("~/Views/WarehouseTransfers/Index.AdvancedSearch.cshtml")
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="WarehouseTransfersTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>@L("TransferCode")</th>
                                        <th>@L("CustomerName")</th>
                                        <th>@L("FromWarehouse")</th>
                                        <th>@L("ToWarehouse")</th>
                                        
                                        <th>@L("Note")</th>
                                        <th>@L("CreationTime")</th>
                                        <th>@L("Status")</th>
                                        <th></th>

                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
