@using pbt.Web.Startup
@using pbt
@using pbt.ApplicationUtils

@model pbt.Web.Models.WarehouseTransfers.CreateWarehouseTransferViewModel

@{
    ViewBag.Title = L("CreateWarehouseTransfer");
    ViewBag.CurrentPageName = PageNames.WarehouseTransfer;

}

@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/WarehouseTransfers/Create.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/WarehouseTransfers/Create.min.js" asp-append-version="true"></script>
    </environment>
}
@section styles{
    <style>
        .select2-container--default .select2-selection--multiple .select2-selection__choice {
            background-color: #007bff;
        }
    </style>
}

<section class="content-header">
    <div class="row">
        <div class="col-4">
            <h1>@L("CreateWarehouseTransfer") <span class="text-danger" id="lbWTCode"></span></h1>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-6">
                <div class="card">
                    <div class="card-body">
                        <form id="form-transfer" onsubmit="return false;">
                            <input type="hidden" name="Id" id="hiddenWTId" />

                            <div class="custom-container">
                                <!-- Kho nguồn -->
                                <div class="row">
                                    <div class="col-6">
                                        <div class="form-group">
                                            <label class="section-title">@L("FromWarehouse")</label>
                                            <select class="form-control select2" id="sourceWarehouse" name="SourceWarehouseId">

                                                @if (Model.Warehouses != null && Model.Warehouses.Any())
                                                {
                                                    foreach (var warehouse in Model.Warehouses)
                                                    {
                                                        if (@warehouse.Id == Model.CurrentUserWarehouseId)
                                                        {
                                                            <option value="@warehouse.Id" data-name="@warehouse.Name" data-address="@warehouse.FullAddress" selected>@warehouse.Name</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@warehouse.Id" data-name="@warehouse.Name" data-address="@warehouse.FullAddress">@warehouse.Name</option>
                                                        }
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <!-- Kho đích -->
                                        <div class="form-group">
                                            <label class="section-title">@L("ToWarehouse")</label>
                                            <select class="form-control select2" id="destinationWarehouse" name="DestinationWarehouseId">

                                                @if (Model.Warehouses != null && Model.Warehouses.Any())
                                                {

                                                    foreach (var warehouse in Model.Warehouses)
                                                    {
                                                        if (@warehouse.Id == Model.CurrentUserWarehouseId)
                                                        {
                                                            <option value="@warehouse.Id" data-name="@warehouse.Name" data-address="@warehouse.FullAddress">@warehouse.Name</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@warehouse.Id" data-name="@warehouse.Name" data-address="@warehouse.FullAddress" selected>@warehouse.Name</option>
                                                        }
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <!-- Kho đích -->
                                        <div class="form-group">
                                            <label class="section-title">@L("Customer")</label>
                                            <select name="CustomerId" class="form-control select2" id="customer-select">
                                                <option value="-1"> @L("SelectCustomer")</option>
                                                @if (Model.Customers != null && Model.Customers.Any())
                                                {
                                                    foreach (var customer in Model.Customers)
                                                    {
                                                        <option value="@customer.Id">@customer.Username</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <!-- Kho đích -->
                                        <div class="form-group">
                                            <label class="section-title">Phí chuyển kho</label>
                                            <input type="text" class="form-control" id="shippingFee" name="ShippingFee" value="0" placeholder="@L("EnterShippingFee")">
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <!-- Quét mã -->
                                        <div class="form-group">
                                            <label class="section-title">@L("ScanCode")</label>
                                            <input type="text" class="form-control mt-2" id="scanCode" name="ScanCode" placeholder="@L("EnterBagOrPackageCode")">
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <!-- Quét mã -->
                                        <div class="form-group">
                                            <label class="section-title">Khách hàng đã quét</label>
                                            <select class="select2  form-control" id="select-customer-scaned">
                                            </select>
                                        </div>
                                    </div>



                                </div>
                            </div>
                        </form>


                        <hr>
                        <h5 class="customer-title">@L("BagAndPackageList")</h5>

                        <div class="table-responsive">
                            <table id="bag-package-listTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>Mã kiện</th>
                                        <th>Mã bao</th>
                                        <th>Tổng cân nặng</th>
                                        <th>Ngày nhập</th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-6">
                <div class="customer-data card">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-12">

                                <div class="table-responsive">
                                    <table id="ready-listTable" class="table table-striped table-bordered">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>Mã kiện</th>
                                                <th>Mã bao</th>
                                                <th>Tổng cân nặng</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                        <div class="form-row">

                            <div class="form-group col-md-12">
                                <label for="note">@L("Note")</label>
                                <textarea class="form-control" id="txtNote" name="Note" rows="5" placeholder="@L("EnterNote")"></textarea>
                            </div>
                        </div>
                        <div class="text-right">
                            <button class="btn btn-primary btn-save-transfer" type="button">@L("SaveAndTransfer")</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>