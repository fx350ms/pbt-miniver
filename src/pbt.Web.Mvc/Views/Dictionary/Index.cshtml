@using pbt.Web.Models.Dicsionarys
@using pbt.Web.Startup
@using pbt.Dictionary.Dto;

@{
    ViewBag.Title = L("Dictionarys");
    ViewBag.CurrentPageName = PageNames.Dictionarys;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/Dictionary/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Dictionary/Index.min.js" asp-append-version="true"></script>
    </environment>
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("Dictionary")</h1>
            </div>
            <div class="col-sm-6">
                <a href="javascript:;" data-toggle="modal" data-target="#DictionaryCreateModal" class="btn bg-blue float-sm-right">
                    <i class="fa fa-plus-square"></i>
                    @L("Create")
                </a>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-6">
                                <!--Use for bulk actions-->
                            </div>
                            <div class="col-md-6">
                                @await Html.PartialAsync("~/Views/Dictionary/Index.AdvancedSearch.cshtml")
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="DictionaryTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>@L("NameVi")</th>
                                        <th>@L("NameCn")</th>
                                        <th>@L("Description")</th>
                                        <th ></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/Dictionary/_CreateModal.cshtml", new CreateUpdateDictionary() { Dictionary = new CreateUpdateDictionaryDto() }) ;

<div class="modal fade" id="DictionaryEditModal" tabindex="-1" role="dialog" aria-labelledby="DictionaryEditModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>
