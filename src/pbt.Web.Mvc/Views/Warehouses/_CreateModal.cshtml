@using pbt.Web.Models.Common.Modals
@using pbt.Web.Models.Warehouses

@model CreateUpdateWarehouse
@{
    Layout = null;
}
<div class="modal fade" id="DepartmentCreateModal" tabindex="-1" role="dialog" aria-labelledby="DepartmentCreateModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            @await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("Create")))
            <form name="departmentCreateForm" role="form" class="form-horizontal">
                <div class="modal-body">
                    <ul class="nav nav-tabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" data-toggle="tab" role="tab" href="#create-department-details">@L("ParentDetails")</a>
                        </li>
                    </ul>
                    <div class="tab-content mt-4">
                        <div role="tabpanel" class="tab-pane container active" id="create-department-details">
                            <div class="form-group row required">
                                <label class="col-md-3 col-form-label">@L("Name")</label>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" name="Name">
                                </div>
                            </div>
                            <div class="form-group row required">
                                <label class="col-md-3 col-form-label">@L("Code")</label>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" name="Code">
                                </div>
                            </div>
                            <div class="form-group row required">
                                <label class="col-md-3 col-form-label">@L("Country")</label>
                                <div class="col-md-9">
                                    <select class="form-control" name="CountryId" id="CountryId">
                                        <option value="2" selected="selected">@L("Vietnam")</option>
                                        <option value="1">@L("China")</option>
                                        
                                    </select>
                                    <input type="hidden" class="form-control" name="Country" id="Country">
                                </div>
                            </div>

                            <div class="form-group row required">
                                <label class="col-md-3 col-form-label">@L("Phone")</label>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" name="Phone">
                                </div>
                            </div>
                           
                            <div class="form-group row required" data-country="2">
                                <label class="col-md-3 col-form-label">@L("City")</label>
                                <div class="col-md-9">
                                    <select id="ProvinceId" class="form-control" name="City">
                                    </select>
                                </div>
                            </div>
                            <div class="form-group row required" data-country="2">
                                <label class="col-md-3 col-form-label">@L("District")</label>
                                <div class="col-md-9">
                                    <select class="form-control" name="District" id="DistrictId">
                                    </select>
                                </div>
                            </div>
                            <div class="form-group row required" data-country="2">
                                <label class="col-md-3 col-form-label">@L("Ward")</label>
                                <div class="col-md-9">
                                    <select class="form-control" name="Ward" id="WardId">
                                    </select>
                                </div>
                            </div>
                            <div class="form-group row required">
                                <label class="col-md-3 col-form-label">@L("Address")</label>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" name="Address" id="Address">
                                    <input type="hidden" class="form-control" name="FullAddress" id="fullAddress">
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-md-3 col-form-label">@L("Status")</label>
                                <div class="col-md-9">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="Status" value="true">
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                @await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
            </form>
        </div>
    </div>
</div>
