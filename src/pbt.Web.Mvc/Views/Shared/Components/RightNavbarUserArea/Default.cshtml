@using System.Security.Principal

@model pbt.Web.Views.Shared.Components.RightNavbarUserArea.RightNavbarUserAreaViewModel
@if (User.Identity.IsAuthenticated)
{
    <li class="nav-item dropdown">
        <a href="javascript:void(0);" class="nav-link" data-toggle="dropdown" role="button">
            <span class="d-none d-md-inline-block">@User.Identity.Name</span>
        </a>
    </li>
    <li class="nav-item dropdown nav-user-menu">
        <a href="javascript:void(0);" class="nav-link" data-toggle="dropdown" role="button">
            <img class="user-image img-circle elevation-2" src="~/libs/admin-lte/dist/img/avatar5.png" alt="User Image">
        </a>
        <div class="dropdown-menu dropdown-menu-right">
            <a class="dropdown-item" asp-controller="Users" asp-action="ChangePassword">
                <i class="fas fa-user-edit"></i> @L("UpdatePassword")
            </a>
            <a class="dropdown-item" asp-controller="Users" asp-action="Information">
                <i class="fas fa-info-circle"></i> @L("Information")
            </a>
            <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                <i class="fas fa-sign-out-alt"></i> @L("Logout")
            </a>
        </div>
    </li>
}