@using pbt.Web.Startup
@using pbt.Customers.Dto;
@using pbt.Web.Models.Customers;
@model CustomerIndexViewModel
@{
    ViewBag.Title = L("CustomerChilds");
    ViewBag.CurrentPageName = PageNames.Customer;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/Customers/IndexChilds.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Customers/IndexChilds.min.js" asp-append-version="true"></script>
    </environment>
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("CustomerChilds") - @ViewBag.customerName</h1>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <input type="hidden" name="customerId" id="customerId" value="@ViewBag.customerId" />
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-6">
                                <!--Use for bulk actions-->
                                @* nếu là sale admin thì cho phép thêm khách hàng con *@
                                @if (User.IsInRole("saleadmin") || User.IsInRole("admin"))
                                {
                                    <button
                                        data-toggle="modal"
                                        data-target="#AddChildCustomerModal"
                                        class="btn btn-sm btn-primary add-customer">@L("AddChildCustomer")</button>
                                }
                            </div>
                            <div class="col-md-6">
                                @await Html.PartialAsync("~/Views/Customers/Index.AdvancedSearch.cshtml", Model)
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="CustomersTable" class="table table-striped table-bordered">
                                <thead>
                                <tr>
                                    <th><input type="checkbox" data-check="all"/></th>
                                    <th></th>
                                    <th>@L("STT")</th>
                                    <th>@L("Account")</th>
                                    <th>@L("FullName")</th>
                                    <th>@L("PhoneNumber")</th>
                                    <th>@L("Email")</th>
                                    <th>@L("CurrentAmount")</th>
                                    <th>@L("CurrentDebt")</th>
                                    <th>@L("MaxDebt")</th>
                                    <th></th>
                                </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/Customers/_CreateModal.cshtml", new CreateUpdateCustomerDto() { }) ;
<script src="~/view-resources/Views/Customers/_CreateModal.js" asp-append-version="true"></script>


<div class="modal fade" id="CustomerEditModal" tabindex="-1" role="dialog" aria-labelledby="CustomerEditModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>

<div class="modal fade" id="CustomerAssignToSaleModal" tabindex="-1" role="dialog" aria-labelledby="CustomerAssignToSaleModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>

<div class="modal fade" id="CustomerLinkToUserModal" tabindex="-1" role="dialog" aria-labelledby="CustomerLinkToUserModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>


<div class="modal fade" id="CustomerResetPassword" tabindex="-1" role="dialog" aria-labelledby="CustomerResetPassword" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>

<div class="modal fade" id="CustomerUpdateMaxDebt" tabindex="-1" role="dialog" aria-labelledby="CustomerUpdateMaxDebt" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>
<div class="modal fade" id="AddChildCustomerModal" tabindex="-1" role="dialog" aria-labelledby="" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>