@using Abp.Application.Services.Dto;
@using pbt.Web.Models.Common.Modals;
@using pbt.Web.Models.Customers;
@{
    Layout = null;
}

@model pbt.Customers.Dto.UpdateMaxDebtDto


@await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("UpdateMaxDebt")))
<form name="CustomerUpdateDebtForm" role="form" class="form-horizontal">
   <input type="hidden" name="CustomerId" value="@Model.CustomerId" />
    <div class="modal-body">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" data-toggle="tab" role="tab" href="#create-user-details">@L("GeneralInfomation")</a>
            </li>
        </ul>
        <div class="tab-content mt-4">
            <div role="tabpanel" class="tab-pane container active">
                <div class="form-group row required">
                    <label class="col-md-3 col-form-label">@L("MaxDebt")</label>
                    <div class="col-md-9">
                        <input class="form-control number-mask" type="text" name="MaxDebt" placeholder="@L("InputMaxDebt")"/>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
</form>

<script src="~/view-resources/Views/Customers/_UpdateMaxDebt.js" asp-append-version="true"></script>