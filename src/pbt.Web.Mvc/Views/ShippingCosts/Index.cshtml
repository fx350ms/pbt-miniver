@using pbt.Web.Startup
@using pbt.ShippingCosts.Dto
@using pbt.Web.Models.Common.Modals
@using pbt.Web.Models.ShippingCosts;
@{
    ViewBag.Title = L("ShippingCostGroups");
 //   ViewBag.CurrentPageName = PageNames.ShippingCostGroup;
}
@model ShippingCostIndexViewModel
@section styles {
    <style>
        .select2-selection--single {
            height: 38px !important;
        }

        .select2-container {
            z-index: 99999;
            min-width: 350px;
        }
    </style>
}

@section scripts {
    <environment names="Development">
        <script src="~/view-resources/Views/ShippingCosts/Index.js" asp-append-version="true"></script>
    </environment>
    <environment names="Staging,Production">
        <script src="~/view-resources/Views/ShippingCosts/Index.min.js" asp-append-version="true"></script>
    </environment>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("ShippingCostGroups")</h1>
            </div>
            <div class="col-sm-6">
                <a href="javascript:;" data-toggle="modal" data-target="#ShippingCostGroupCreateModal" class="btn bg-blue float-sm-right">
                    <i class="fa fa-plus-square"></i> @L("CreateNew")
                </a>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-12">
                                @await Html.PartialAsync("~/Views/ShippingCosts/Index.AdvancedSearch.cshtml", Model)
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="ShippingCostGroupsTable" class="table table-striped table-bordered">
                                <thead>
                                <tr>
                                    <th>@L("STT")</th>
                                    <th>@L("Name")</th>
                                    <th>@L("ShippingPartner")</th>
                                    <th>@L("IsActived")</th>
                                    <th>@L("FromDate")</th>
                                    <th>@L("ToDate")</th>
                                    <th>@L("Note")</th>
                                    <th></th>
                                </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="ShippingCostGroupEditModal" tabindex="-1" role="dialog" aria-labelledby="ShippingCostGroupCreateModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/ShippingCosts/_CreateModal.cshtml",  Model)