@using pbt.Web.Startup

@using pbt.FundAccounts.Dto;

@{
    ViewBag.Title = L("FundAccounts");
    ViewBag.CurrentPageName = PageNames.FundAccounts;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/FundAccount/Index.js" asp-append-version="true"></script>

    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/FundAccount/Index.min.js" asp-append-version="true"></script>
    </environment>
    
  

}
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("FundAccount")</h1>
            </div>
            <div class="col-sm-6">
                <a href="javascript:;" data-toggle="modal" data-target="#FundAccountCreateModal" class="btn bg-blue float-sm-right">
                    <i class="fa fa-plus-square"></i>
                    @L("Create")
                </a>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-6">
                                <!--Use for bulk actions-->
                            </div>
                            <div class="col-md-6">
                                @await Html.PartialAsync("~/Views/FundAccount/Index.AdvancedSearch.cshtml")
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="FundAccountsTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>@L("AccountName")</th>
                                        <th>@L("AccountType")</th>
                                        <th>@L("Currency")</th>
                                        <th>@L("BankName")</th>
                                        <th>@L("AccountNumber")</th>
                                        <th>@L("AccountHolder")</th>
                                        <th>@L("TotalFundAmount")</th>
                                        <th>@L("Notes")</th>
                                        <th>@L("Status")</th>
                                        <th style="width: 150px">@L("Actions")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/FundAccount/_CreateModal.cshtml", new FundAccountDto() {   });

<div class="modal fade" id="FundAccountEditModal" tabindex="-1" role="dialog" aria-labelledby="FundAccountEditModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>

<div class="modal fade" id="AssignToUserModal" tabindex="-1" role="dialog" aria-labelledby="AssignToUserModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

        </div>
    </div>
</div>

