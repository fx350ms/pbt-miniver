@using pbt.Web.Models.DeliveryNote
@using pbt.ApplicationUtils

@model MyDeliveryNoteIndexViewModel

<div class="abp-advanced-search" xmlns="http://www.w3.org/1999/html">
    <button class="btn btn-outline-primary mb-2" type="button" data-toggle="collapse" data-target="#BagFilterCollapse">
        <i class="fas fa-filter"></i> Bộ lọc nâng cao
    </button>

    <div class="collapse" id="BagFilterCollapse">
        <form id="PackageSearchForm" class="form-horizontal">
            <input type="hidden" name="FilterType" value="all" />
            <div class="form-row mb-3">
                <div class="col-md-2">
                    <label for="Keyword">@L("Keyword")</label>
                    <input type="text" name="Keyword" class="form-control txt-search" placeholder="@L("Search")" />
                </div>
               
                <div class="col-md-2">
                    <label>@L("Customer")</label>
                    <select class="select2 form-control" id="CustomerSelect" name="CustomerId" style="width: 100%;">
                        <option value="">@L("All")</option>
                        @if (Model != null && Model.Customers != null && Model.Customers.Count > 0)
                        {
                            foreach (var customer in Model.Customers)
                            {
                                <option value="@customer.id">@customer.text</option>
                            }
                        }

                    </select>
                </div>
                 
                <div class="col-md-3">
                    <label for="CreateDate">@L("CreateDate")</label>
                    <div class="input-group">
                        <input type="text" class="form-control date-range" name="CreateDate" id="CreateDate"
                            target="create-date">
                        <div class="input-group-append">
                            <button type="button" class="btn btn-outline-danger btn-clear-date" target="CreateDate"
                                target-date="create-date" style="border: none;">
                                <i class="fa fa-times-circle"></i>
                            </button>
                        </div>
                    </div>
                    <input type="hidden" class="form-control float-right start-date create-date"
                        name="CreateStartDateStr" id="start-create-date">
                    <input type="hidden" class="form-control float-right end-date create-date" name="CreateEndDateStr"
                        id="end-create-date">
                </div>
                <div class="col-md-3">
                    <label for="ExportDate">@L("ExportDateVN")</label>
                    <div class="input-group">
                        <input type="text" class="form-control date-range" name="ExportDate" id="ExportDate"
                            target="export-date">
                        <div class="input-group-append">
                            <button type="button" class="btn btn-outline-danger btn-clear-date" target="ExportDate"
                                target-date="export-date" style="border: none;">
                                <i class="fa fa-times-circle"></i>
                            </button>
                        </div>
                    </div>
                    <input type="hidden" class="form-control float-right start-date export-date"
                        name="ExportStartDateVNStr" id="start-export-date">
                    <input type="hidden" class="form-control float-right end-date export-date" name="ExportEndDateVNStr"
                        id="end-export-date">
                </div>
             

                <div class="col-md-1 text-right">
                    <label style="display: block" for="">&nbsp;</label>
                    <button type="button" style="width: auto" class="btn btn-primary btn-search form-control">
                        <i class="fas fa-search"></i> @L("Search")
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>