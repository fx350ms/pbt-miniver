<div class="abp-advanced-search">
    <form id="ConfigurationSettingSearchForm" class="form-inline">
        <div class="form-group mr-2">
            <label for="SearchKey" class="mr-2">@L("Key")</label>
            <input type="text" class="form-control" id="SearchKey" name="Key" placeholder="@L("EnterKey")">
        </div>
        <div class="form-group mr-2">
            <label for="SearchValue" class="mr-2">@L("Value")</label>
            <input type="text" class="form-control" id="SearchValue" name="Value" placeholder="@L("EnterValue")">
        </div>
        <button type="button" class="btn btn-primary btn-search">
            <i class="fas fa-search"></i> @L("Search")
        </button>
        <button type="button" class="btn btn-secondary btn-clear ml-2">
            <i class="fas fa-eraser"></i> @L("Clear")
        </button>
    </form>
</div>