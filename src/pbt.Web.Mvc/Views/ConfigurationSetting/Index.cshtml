@using pbt.ConfigurationSettings.Dto
@using pbt.Web.Startup

@{
    ViewBag.Title = L("ConfigurationSettings");
   // ViewBag.CurrentPageName = PageNames.ConfigurationSettings;
}

@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/ConfigurationSetting/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/ConfigurationSetting/Index.min.js" asp-append-version="true"></script>
    </environment>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("ConfigurationSettings")</h1>
            </div>
            <div class="col-sm-6">
                <a href="javascript:;" data-toggle="modal" data-target="#ConfigurationSettingCreateModal" class="btn bg-blue float-sm-right">
                    <i class="fa fa-plus-square"></i>
                    @L("Create")
                </a>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-6">
                                <!-- Use for bulk actions -->
                            </div>
                            <div class="col-md-6">
                                @await Html.PartialAsync("~/Views/ConfigurationSetting/Index.AdvancedSearch.cshtml")
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="ConfigurationSettingTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>@L("Key")</th>
                                        <th>@L("Value")</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/ConfigurationSetting/_CreateModal.cshtml", new ConfigurationSettingDto());

<div class="modal fade" id="ConfigurationSettingEditModal" tabindex="-1" role="dialog" aria-labelledby="ConfigurationSettingEditModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>