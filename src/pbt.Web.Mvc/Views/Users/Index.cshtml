@using pbt.Web.Startup
@using pbt.Web.Models.Users
@using pbt.Authorization
@using pbt.Web.Models.Common.Modals

@model UserListViewModel
@{
    ViewBag.Title = L("Users");
    ViewBag.CurrentPageName = PageNames.Users;
}
@section scripts
{
    @if (PermissionChecker.IsGranted(PermissionNames.Function_EditUserSpecialPIN))
    {
        <script>
            let allowResetPinPermission = true;
        </script>
    }
    else
    {
        <script>
            let allowResetPinPermission = false;
        </script>
    }

    @if (PermissionChecker.IsGranted(PermissionNames.Role_Admin))
    {
        <script>
            let isAdmin = true;
        </script>
    }
    else
    {
        <script>
            let isAdmin = false;
        </script>
    }


    <environment names="Development">
        <script src="~/view-resources/Views/Users/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Users/Index.min.js" asp-append-version="true"></script>
    </environment>

}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("Users")</h1>
            </div>
            <div class="col-sm-6">
                <a href="javascript:;" data-toggle="modal" data-target="#UserCreateModal" class="btn bg-blue float-sm-right">
                    <i class="fa fa-plus-square"></i>
                    @L("Create")
                </a>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-6">
                                <!--Use for bulk actions-->
                                <button class="btn btn-outline-primary mb-2 mr-2" type="button" data-toggle="collapse" data-target="#UserFilterCollapse">
                                    <i class="fas fa-filter"></i> Bộ lọc nâng cao
                                </button>
                            </div>
                            <div class="col-md-6">
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                @await Html.PartialAsync("~/Views/Users/Index.AdvancedSearch.cshtml", Model)
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="UsersTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>@L("Id")</th>
                                        <th>@L("UserName")</th>
                                        <th>@L("Roles")</th>
                                        <th>@L("EmailAddress")</th>
                                        <th>@L("IsActive")</th>
                                        <th>@L("AccountType")</th>

                                        <th>@L("WarehouseName")</th>
                                        <th>Quản lý</th>

                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/Users/_CreateModal.cshtml", Model)

<div class="modal fade" id="UserEditModal" tabindex="-1" role="dialog" aria-labelledby="UserEditModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>
<div class="modal fade" id="UserResetPasswordModal" tabindex="-1" role="dialog" aria-labelledby="UserResetpasswordModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>

<div class="modal fade" id="UserResetPINModal" tabindex="-1" role="dialog" aria-labelledby="UserResetpasswordModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            @await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("ChangePassword")))
            <form name="UserResetPINForm" role="form" class="form-horizontal">
                <input type="hidden" name="UserId" />
                <div class="modal-body">

                    <div class="tab-content mt-4">
                        <div role="tabpanel" class="tab-pane container active">
                            <div class="form-group row required">
                                <label class="col-md-3 col-form-label">@L("SpecialPassword")</label>
                                <div class="col-md-9">
                                    <input class="form-control" type="text" name="NewPassword" placeholder="@L("InputPassword")" />
                                </div>
                            </div>
                            <div class="form-group row required">
                                <label class="col-md-3 col-form-label">@L("ConfirmSpecialPassword")</label>
                                <div class="col-md-9">
                                    <input class="form-control" type="text" name="ConfirmPassword" placeholder="@L("ConfirmPassword")" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-default close-button" data-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary save-button ">Lưu</button>
                </div>
            </form>


        </div>
    </div>
</div>


<div class="modal fade" id="SelectSaleAdminModal" tabindex="-1" role="dialog" aria-labelledby="" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            @await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("SelectSaleAdmin")))
            <form name="SelectSaleAdminForm" id="SelectSaleAdminForm" role="form" class="form-horizontal" onsubmit="return false;">
                <input type="hidden" name="UserId" />
                <div class="modal-body">

                    <div class="tab-content mt-4">
                        <div role="tabpanel" class="tab-pane container active">
                            <div class="form-group row required">
                                <label class="col-md-3 col-form-label">@L("SelectSaleAdmin")</label>
                                <div class="col-md-9">
                                    <select class="form-control" id="SaleAdminUserId" name="SaleAdminUserId">
                                        <option value="">@L("SelectSaleAdmin")</option>
                                        @foreach (var user in Model.SaleAdminUsers)
                                        {
                                            <option value="@user.Id">@user.UserName</option>
                                        }
                                    </select>
                                </div>
                            </div>
                           
                        </div>
                    </div>
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-default close-button" data-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary save-button ">Lưu</button>
                </div>
            </form>


        </div>
    </div>
</div>
