@using pbt.ApplicationUtils
@using pbt.CustomerAddresss.Dto
@using pbt.Web.Startup
@model pbt.Web.Models.DeliveryRequests.CreateUpdateDeliveryRequest

@{
    ViewBag.Title = L("CreateDeliveryRequest");
}

@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/DeliveryRequest/Create.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/DeliveryRequest/Create.min.js" asp-append-version="true"></script>
    </environment>
}
@section styles {
    <style>
        .select2-selection--single {
            height: 38px !important;
        }

        .select2-dropdown {
            z-index: 9999;
        }

        .active {
            background-color: #ffecc8;
        }
    </style>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("CreateDeliveryRequest")</h1>
            </div>
            <div class="col-sm-6 text-right">
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <form id="form-dr" onsubmit="return false;">
            <div class="row">
                <div class="col-6">
                    <div class="card">
                        <div class="card-body text-sm">

                            <div class="custom-container">
                                <!-- Kho nguồn -->
                                <div class="row">
                                    <div class="col-6">
                                        <div class="form-group">
                                            <label class="section-title">@L("Warehouse")</label>
                                            <select class="form-control select2" id="select-warehouse"
                                                    name="WarehouseId">
                                                @if (Model.Warehouses != null && Model.Warehouses.Any())
                                                {
                                                    <option value="-1" selected>Chọn kho</option>
                                                    foreach (var warehouse in Model.Warehouses)
                                                    {
                                                        <option value="@warehouse.Id" data-name="@warehouse.Name"
                                                                data-address="@warehouse.FullAddress">
                                                            @warehouse.Name
                                                        </option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <!-- Kho đích -->
                                        <div class="form-group">
                                            <label class="section-title">@L("Customer")</label>
                                            <select name="CustomerId" class="form-control select2" id="customer-select">
                                                <option value="-1"> @L("SelectCustomer")</option>
                                                @if (Model.Customers != null && Model.Customers.Any())
                                                {
                                                    foreach (var customer in Model.Customers)
                                                    {
                                                        <option value="@customer.Id">@customer.Username</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <hr>
                            <h5 class="customer-title">@L("BagAndPackageList")</h5>
                            <div class="table-responsive">
                                <table id="bag-package-listTable" class="table table-striped table-bordered table-sm">
                                    <thead>
                                        <tr>
                                            <th>Mã bao</th>
                                            <th>Mã kiện</th>
                                            <th>Vận đơn</th>
                                            <th>C/nặng</th>
                                            <th>Ngày nhập</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="col-6">
                    <div class="customer-data card">
                        <div class="card-header text-sm">
                            <h4>Yêu cầu giao <span id="deliveryRequestNumber" class="text-info"></span></h4>
                        </div>
                        <div class="card-body text-sm">
                            <div class="row">
                                <div class="col-12">
                                    <input type="hidden" name="DeliveryRequestId" id="hiddenDeliveryRequestId" />
                                    <div class="table-responsive">
                                        <table id="deliveryRequestItemTable"
                                               class="table table-striped table-bordered table-sm">
                                            <thead>
                                                <tr>
                                                    <th></th>
                                                    <th>Mã bao</th>
                                                    <th>Mã kiện</th>
                                                    <th>Vận đơn</th>
                                                    <th>C/nặng</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>
                                    </div>

                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-md-12">
                                    <label for="note">@L("Note")</label>
                                    <textarea class="form-control" id="txtNote" name="Note" rows="5"
                                              placeholder="@L("EnterNote")"></textarea>
                                </div>
                            </div>
                            <div class="form-row">
                              
                                <div class="col-md-9">
                                    <label><strong>Địa chỉ</strong></label>
                                    <textarea class="form-control" id="txtAddress" name="Address" rows="2"
                                              placeholder="@L("EnterAddress")"></textarea>
                                </div>
                                <div class="col-md-3">
                                    <label><strong>Phương thức vận chuyển</strong></label>
                                    <select class="form-control" name="ShippingMethod" id="ShippingMethod">
                                        <option value="@((int)ShippingMethod.Delivery)">@ShippingMethod.Delivery.GetDescription()</option>
                                        <option value="@((int)ShippingMethod.Warehouse)">@ShippingMethod.Warehouse.GetDescription()</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-row " style="margin-top:10px;">
                                <div class="col-md-12 text-right">
                                    <button id="btn-submit-dr" class="btn btn-primary btn-submit d-none"
                                            type="button">
                                        @L("SubmitRequest")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@await Html.PartialAsync("~/Views/DeliveryRequest/_CreateAddressModal.cshtml", new CustomerAddressDto() { })