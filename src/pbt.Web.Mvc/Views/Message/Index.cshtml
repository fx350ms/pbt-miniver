@using pbt.Transactions.Dto
@using pbt.Web.Startup

@using pbt.Messages.Dto;

@{
    ViewBag.Title = L("Messages");
    ViewBag.CurrentPageName = PageNames.Message;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/Messages/Index.js" asp-append-version="true"></script>
    </environment>
    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Messages/Index.min.js" asp-append-version="true"></script>
    </environment>

    <environment names="Development">
        <script src="~/view-resources/Views/Messages/CreateReceipt.js" asp-append-version="true"></script>
    </environment>
    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Messages/CreateReceipt.min.js" asp-append-version="true"></script>
    </environment>
}

@section styles {
    <style>
        .select2-selection--single {
            height: 38px !important;
        }

        .select2-selection__arrow {
            top: 5px !important;
        }

        .select2-dropdown {
            z-index: 9999;
        }
    </style>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("Messages")</h1>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                           
                            <div class="col-12">
                                @await Html.PartialAsync("~/Views/Message/Index.AdvancedSearch.cshtml")
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="MessagesTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>@L("DeviceName")</th>
                                        <th>@L("DeviceId")</th>
                                        <th>@L("Content")</th>
                                        <th>@L("Status")</th>
                                        <th>@L("Progress")</th>
                                        <th>@L("MessageType")</th>
                                        <th>@L("IsCorrectSyntax")</th>
                                        <th>@L("CreatedDate")</th>
                                        <th ></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


@await Html.PartialAsync("~/Views/Message/_CreateReceiptModal.cshtml", new TransactionDto())