@using pbt.Web.Startup
@using pbt.Authorization
@using pbt.ApplicationUtils
@using pbt.Orders.Dto
@using pbt.Web.Models.SaleAdmin

@model SaleAdminIndexModel

@inject pbtAppSession AppSession

@{
    ViewBag.Title = L("SaleAdminDashboard");
    ViewBag.CurrentPageName = PageNames.Orders;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/SaleAdmin/Bags.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/SaleAdmin/Bags.min.js" asp-append-version="true"></script>
    </environment>
}
 
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("BagWithPartner")</h1>
            </div>
            <div class="col-sm-6 text-right">
                <button type="button" class="btn btn-primary btn-export-excel">
                    <i class="fas fa-file-excel"></i> @L("ExportExcel")
                </button>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">

                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-12">

                                <div class="abp-advanced-search">
                                    <!-- Nút mở rộng/thu gọn -->
                                    <button class="btn btn-outline-primary mb-2" type="button" data-toggle="collapse" data-target="#BagFilterCollapse">
                                        <i class="fas fa-filter"></i> Bộ lọc nâng cao
                                    </button>

                                    <div class="collapse" id="BagFilterCollapse">
                                        <form id="BagSearchForm" class="form-horizontal">

                                            <div class="form-row">
                                                <div class="col-md-3">
                                                    <label for="Keyword">@L("Keyword")</label>
                                                    <div class="input-group">
                                                        <input type="text" name="Keyword" class="form-control txt-search" placeholder="@L("Search")" id="txt-keyword">
                                                        <span class="input-group-append">
                                                            <button type="button" class="btn btn-flat btn-clear-value" target="Keyword">
                                                                <i class="fas fa-times-circle text-danger"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>
                                            
                                                <div class="col-md-2">
                                                    <label for="Status">@L("ShippingPartner")</label>
                                                    <div class="input-group input-group">
                                                        <select class="form-control" name="ShippingPartnerId" id="ShippingPartner" placeholder="@L("ShippingPartner")">
                                                            <option value="-1">@L("All")</option>
                                                            @foreach (var item in Model.ShippingPartners)
                                                            {
                                                                <option value="@((int)item.Id)">@item.Name</option>
                                                            }
                                                        </select>
                                                        <span class="input-group-append">
                                                            <button type="button" class="btn btn-flat btn-clear-value" target="ShippingPartnerId" target-value="-1">
                                                                <i class="fas fa-times-circle text-danger"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>

                                                <!-- Line vận chuyển -->
                                                <div class="col-md-2">
                                                    <label for="Keyword">@L("Line")</label>
                                                    <div class="input-group input-group">
                                                        <select class="form-control" id="ShippingLine" name="ShippingLine">
                                                            <option value="-1">-- @L("All") --</option>
                                                            <option value="@((int)LineShipping.InformalTrade)">@L("LineShipping.InformalTrade")</option>
                                                            <option value="@((int)LineShipping.Ecommerce)">@L("LineShipping.Ecommerce")</option>
                                                            <option value="@((int)LineShipping.OfficialChannel)">@L("LineShipping.OfficialChannel")</option>
                                                            <option value="@((int)LineShipping.Portable)">@L("LineShipping.Portable")</option>
                                                        </select>
                                                        <span class="input-group-append">
                                                            <button type="button" class="btn btn-flat btn-clear-value" target="ShippingLine" target-value="-1">
                                                                <i class="fas fa-times-circle text-danger"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>

                                                <!-- Line vận chuyển -->
                                                <div class="col-md-2">
                                                    <label for="Status">@L("BagType")</label>
                                                    <div class="input-group input-group">
                                                        <select class="form-control" name="BagType" id="BagType" placeholder="@L("BagType")">
                                                            <option value="-1">@L("All")</option>
                                                            <option value="@((int)BagTypeEnum.SeparateBag)">@L("BagTypeEnum.SeparateBag")</option>
                                                            <option value="@((int)BagTypeEnum.InclusiveBag)">@L("BagTypeEnum.InclusiveBag")</option>
                                                        </select>
                                                        <span class="input-group-append">
                                                            <button type="button" class="btn btn-flat btn-clear-value" target="BagType" target-value="-1">
                                                                <i class="fas fa-times-circle text-danger"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>

                                                <!-- Trạng thái -->
                                                <div class="col-md-2">
                                                    <label for="Status">@L("Status")</label>
                                                    <div class="input-group input-group">
                                                        <select name="Status" class="form-control" id="select-filter-order-status">
                                                            <option value="-1">-- @L("All") --</option>
                                                            <option value="@((int)BagShippingStatus.Initiated)">@L("BagShippingStatus.Initiated")</option>
                                                            <option value="@((int)BagShippingStatus.WaitingForShipping)">@L("BagShippingStatus.WaitingForShipping")</option>
                                                            <option value="@((int)BagShippingStatus.InTransit)">@L("BagShippingStatus.InTransit")</option>
                                                            <option value="@((int)BagShippingStatus.GoToWarehouse)">@L("BagShippingStatus.GoToWarehouse")</option>
                                                            <option value="@((int)BagShippingStatus.WaitingForDelivery)">@L("BagShippingStatus.WaitingForDelivery")</option>
                                                            <option value="@((int)BagShippingStatus.Delivery)">@L("BagShippingStatus.Delivery")</option>
                                                        </select>
                                                        <span class="input-group-append">
                                                            <button type="button" class="btn btn-flat btn-clear-value" target="Status" target-value="-1">
                                                                <i class="fas fa-times-circle text-danger"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>
 
                                                <div class="col-md-3">
                                                    <label for="ExportDate">@L("ExportDateCN")</label>

                                                    <div class="input-group">
                                                        <input type="text" class="form-control date-range" name="ExportDate" id="ExportDate" target="export-date">
                                                        <div class="input-group-append">
                                                            <button type="button" class="btn btn-outline-danger btn-clear-value" target="ExportDate" target-date="export-date" style="border: none;">
                                                                <i class="fa fa-times-circle"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <input type="hidden" class="form-control float-right start-date export-date" name="ExportStartDateStr" id="start-export-date">
                                                    <input type="hidden" class="form-control float-right end-date export-date" name="ExportEndDateStr" id="end-export-date">
                                                </div>

                                                <div class="col-md-3">
                                                    <label for="ImportDate">@L("ImportDateVN")</label>
                                                    <div class="input-group">
                                                        <input type="text" class="form-control date-range" name="ImportDate" id="ImportDate" target="import-date">
                                                        <div class="input-group-append">
                                                            <button type="button" class="btn btn-outline-danger btn-clear-value" target="ImportDate" target-date="import-date" style="border: none;">
                                                                <i class="fa fa-times-circle"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <input type="hidden" class="form-control float-right start-date import-date" name="ImportStartDateStr" id="start-import-date">
                                                    <input type="hidden" class="form-control float-right end-date import-date" name="ImportEndDateStr" id="end-import-date">
                                                </div>

                                                <div class="col-md-3">
                                                    <label for="DeliveryDate">@L("ExportDateVN")</label>
                                                    <div class="input-group">
                                                        <input type="text" class="form-control date-range" name="ExportStartDateVN" id="ExportStartDateVN" target="export-date-vn">
                                                        <div class="input-group-append">
                                                            <button type="button" class="btn btn-outline-danger btn-clear-value" target="ExportStartDateVN" target-date="export-date-vn" style="border: none;">
                                                                <i class="fa fa-times-circle"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <input type="hidden" class="form-control float-right start-date export-date-vn" name="ExportVNStartDateStr" id="start-export-date-vn">
                                                    <input type="hidden" class="form-control float-right end-date export-date-vn" name="ExportVNEndDateStr" id="end-export-date-vn">
                                                </div>

                                                <div class="col-md-3">
                                                    <label>@L("Customer")</label>
                                                    <div class="input-group">
                                                        <select class="select2 form-control" id="CustomerSelect" name="CustomerId" style="width: 80%;"></select> <div class="input-group-append">
                                                            <button type="button" class="btn btn-outline-danger btn-clear-value" target="CustomerSelect" style="border: none;">
                                                                <i class="fa fa-times-circle"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-row mt-3">
                                                <div class="col-md-12 d-flex justify-content-end">
                                                    <button type="button" class="btn btn-primary mr-2 btn-bag-search">
                                                        <i class="fas fa-search"></i> Tìm kiếm
                                                    </button>
                                                </div>
                                            </div>

                                        </form>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="table-responsive">
                            @*    <h2>Tổng cân nặng: <span class="package-total-weight"></span> </h2> *@
                            <table id="BagTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th> </th>
                                        <th>@L("ExportDateCN")</th>
                                        <th>@L("ImportDateVN")</th>
                                        <th>@L("ExportDateVN")</th>
                                        <th>@L("Receiver")</th>
                                        <th>@L("BagCode")</th>
                                        <th>@L("WeightKg")</th>
                                        <th>@L("VolumeM3")</th>
                                        <th>@L("TotalPackage")</th>
                                        <th>@L("ShippingPartner")</th>
                                        <th>@L("Characteristic")</th>
                                     
                                        <th>@L("Note")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
