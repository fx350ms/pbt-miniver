@using pbt.ApplicationUtils

<div class="tab-pane fade" id="bag-list" role="tabpanel" aria-labelledby="custom-tabs-three-home-tab">
    <div class="card-header">
        <div class="row">
            <div class="col-md-12">

                <div class="abp-advanced-search">
                    <!-- Nút mở rộng/thu gọn -->
                    <button class="btn btn-outline-primary mb-2" type="button" data-toggle="collapse" data-target="#BagFilterCollapse">
                        <i class="fas fa-filter"></i> Bộ lọc nâng cao
                    </button>

                    <div class="collapse" id="BagFilterCollapse">
                        <form id="BagSearchForm" class="form-horizontal">

                            <div class="form-row">
                                <div class="col-md-2">
                                    <label for="TransactionDate">Từ khóa</label>
                                    <input type="text" name="Keyword" class="form-control txt-search" placeholder="@L("Search")" />
                                </div>
                                <div class="col-md-2">
                                    <label>@L("Customer")</label>
                                    <select class="select2 form-control" id="CustomerSelect" name="CustomerId" style="width: 100%;"></select>
                                </div>
                                <!-- Trạng thái -->
                                <div class="col-md-2">
                                    <label for="Status">@L("ShippingPartner")</label>
                                    <select class="form-control" name="ShippingPartner"   placeholder="@L("ShippingPartner")">
                                        <option value="-1">@L("All")</option>
                                        @if (Model.ShippingPartners != null)
                                        {
                                            foreach (var item in Model.ShippingPartners)
                                            {
                                                <option value="@((int)item.Id)">@item.Name</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-2">
                                    <label for="CreateDate">@L("ExportDate")</label>
                                    <input type="text" class="form-control date-range" name="ExportDate" id="ExportDate" target="bag-export-date">
                                    <input type="hidden" class="form-control float-right start-date bag-export-date" name="StartExportDateStr">
                                    <input type="hidden" class="form-control float-right end-date bag-export-date" name="EndExportDateStr">
                                </div>
                                <div class="col-md-2">
                                    <label for="CreateDate">@L("ImportDate")</label>
                                    <input type="text" class="form-control date-range" name="ImportDate" id="ImportDate" target="bag-import-date">
                                    <input type="hidden" class="form-control float-right start-date bag-import-date" name="StartImportDateStr" />
                                    <input type="hidden" class="form-control float-right end-date bag-import-date" name="EndImportDateStr"  >
                                </div>
                                <!-- Số kiện -->
                              @*   <div class="col-md-2">
                                    <label for="NumberOfPackage">@L("FromNumberOfPackage")</label>
                                    <input type="number" class="form-control" name="FromNumberOfPackage" min="0" value="0"  placeholder="@L("NumberOfPackage")">
                                </div>
                                <!-- Số kiện -->
                                <div class="col-md-2">
                                    <label for="NumberOfPackage">@L("ToNumberOfPackage")</label>
                                    <input type="number" class="form-control" name="ToNumberOfPackage" min="0" value="0"  placeholder="@L("NumberOfPackage")">
                                </div> *@
                                <!-- Trọng lượng từ -->
                              @*   <div class="col-md-2">
                                    <label for="FromWeight">@L("FromWeight")</label>
                                    <input type="number" class="form-control" name="FromWeight" value="0" id="FromWeight" placeholder="@L("FromWeight")">
                                </div>

                                <!-- Trọng lượng đến -->
                                <div class="col-md-2">
                                    <label for="ToWeight">@L("ToWeight")</label>
                                    <input type="number" class="form-control" name="ToWeight" value="0" id="ToWeight" placeholder="@L("ToWeight")">
                                </div> *@
@* 
                                <!-- Phí ship nội địa từ -->
                                <div class="col-md-2">
                                    <label for="ShipFeeFrom">@L("ShipFeeFrom")</label>
                                    <input type="number" class="form-control" name="ShipFeeFrom" value="0" id="ShipFeeFrom" placeholder="@L("ShipFeeFrom")">
                                </div>

                                <!-- Phí ship nội địa đến -->
                                <div class="col-md-2">
                                    <label for="ShipFeeTo">@L("ShipFeeTo")</label>
                                    <input type="number" class="form-control" name="ShipFeeTo" value="0" id="ShipFeeTo" placeholder="@L("ShipFeeTo")">
                                </div>
 *@@* 
                                <!-- Phí đóng gỗ từ -->
                                <div class="col-md-2">
                                    <label for="WoodPackingFeeFrom">@L("WoodPackingFeeFrom")</label>
                                    <input type="number" class="form-control" name="WoodPackingFeeFrom" id="WoodPackingFeeFrom" placeholder="@L("WoodPackingFeeFrom")">
                                </div>

                                <!-- Phí đóng gỗ đến -->
                                <div class="col-md-2">
                                    <label for="WoodPackingFeeTo">@L("WoodPackingFeeTo")</label>
                                    <input type="number" class="form-control" name="WoodPackingFeeTo" id="WoodPackingFeeTo" placeholder="@L("WoodPackingFeeTo")">
                                </div>
 *@
                                <!-- Line vận chuyển -->
                                <div class="col-md-2">
                                    <label for="ShippingLine">@L("ShippingLine")</label>
                                    <select class="form-control" name="ShippingLine" id="ShippingLine">
                                        <option value="-1">@L("All")</option>
                                        <option value="@((int) LineShipping.Ecommerce)">@LineShipping.Ecommerce.GetDescription()</option>
                                        <option value="@((int) LineShipping.InformalTrade)">@LineShipping.InformalTrade.GetDescription()</option>
                                        <option value="@((int) LineShipping.OfficialChannel)">@LineShipping.OfficialChannel.GetDescription()</option>
                                        <option value="@((int) LineShipping.Portable)">@LineShipping.Portable.GetDescription()</option>
                                    </select>
                                </div>

                            </div>

                            <div class="form-row mt-3">
                                <div class="col-md-12 d-flex justify-content-end">
                                    <button type="button" class="btn btn-primary mr-2 btn-bag-search">
                                        <i class="fas fa-search"></i> Tìm kiếm
                                    </button>

                                </div>
                            </div>

                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="">
        <div class="table-responsive">
            <h2>Tổng cân nặng: <span class="package-total-weight"></span> </h2>
            <table id="BagTable" class="table table-striped table-bordered">
                <thead>
                    <tr>
                      
                        <th>@L("ExportDateCN")</th>
                        <th>@L("Receiver")</th>
                        <th>@L("Code")</th>
                        <th>@L("WeightKg")</th>
                        <th>@L("PackageVolumeM3")</th>
                        <th>@L("D")</th>
                        <th>@L("R")</th>
                        <th>@L("C")</th>
                        <th>@L("TotalPackages")</th>
                        <th>@L("ShippingPartner")</th>
                        <th>@L("Characteristic")</th>
                        <th>@L("ImportDateHN")</th>
                        <th>@L("Note")</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

</div>