

@using pbt.Web.Startup
@using pbt.Authorization
@using pbt.ApplicationUtils
@using pbt.Orders.Dto
@using pbt.Web.Models.SaleAdmin

@model SaleAdminOrderModel

@inject pbtAppSession AppSession

@{
    ViewBag.Title = L("SaleAdminOrder");
    ViewBag.CurrentPageName = PageNames.Orders;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/SaleAdmin/Order.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/SaleAdmin/Order.min.js" asp-append-version="true"></script>
    </environment>
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("SaleAdminOrder")</h1>
            </div>
            <div class="col-sm-6">
            </div>
        </div>
    </div>

</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-6">
                                <!--Use for bulk actions-->

                                <a href="@Url.Action("CreateOrderBySale", "SaleAdmin")" class="btn bg-blue float-sm-right">
                                    <i class="fa fa-plus-square"></i>
                                    @L("CreateCustomerOrder")
                                </a>

                            </div>
                            <div class="col-md-6">
                                @await Html.PartialAsync("~/Views/SaleAdmin/Index.AdvancedSearch.cshtml")
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12 col-sm-6 col-md-3">
                                <div class="info-box bg-lightblue color-palette">
                                    <div class="info-box-content">
                                        <span class="info-box-text">@L("YourCustomerTotal")</span>
                                        <span class="info-box-number">
                                            @Model.TotalCustomer
                                        </span>
                                    </div>
                                    <!-- /.info-box-content -->
                                </div>
                                <!-- /.info-box -->
                            </div>
                            <!-- /.col -->
                            <div class="col-12 col-sm-6 col-md-3">
                                <div class="info-box mb-3 bg-purple color-palette">
                                    <div class="info-box-content">
                                        <span class="info-box-text">@L("TotalRevenue")</span>
                                        <span class="info-box-number"> @Model.TotalRevenue</span>
                                    </div>
                                    <!-- /.info-box-content -->
                                </div>
                                <!-- /.info-box -->
                            </div>
                            <!-- /.col -->
                            <!-- fix for small devices only -->
                            <div class="clearfix hidden-md-up"></div>
                            <div class="col-12 col-sm-6 col-md-3">
                                <div class="info-box mb-3 bg-info color-palette">
                                    <div class="info-box-content">
                                        <span class="info-box-text">@L("ConversionRate")</span>
                                        <span class="info-box-number">  @Model.ConversionRate</span>
                                    </div>
                                    <!-- /.info-box-content -->
                                </div>
                                <!-- /.info-box -->
                            </div>
                            <!-- /.col -->
                            <!-- /.col -->
                        </div>

                        <div class="row">
                            <div class="col-12 col-sm-6 col-md-3">
                                <div class="info-box">
                                    <span class="info-box-icon bg-gray elevation-1">
                                        <i class="fas fa-pause"></i>
                                    </span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">@L("WaitProcessing")</span>
                                        <span class="info-box-number">
                                            @Model.TotalPending

                                        </span>
                                    </div>
                                    <!-- /.info-box-content -->
                                </div>
                                <!-- /.info-box -->
                            </div>
                            <!-- /.col -->
                            <div class="col-12 col-sm-6 col-md-3">
                                <div class="info-box mb-3">
                                    <span class="info-box-icon bg-cyan elevation-1">
                                        <i class="fas fa-cogs"></i>
                                    </span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">@L("Processing")</span>
                                        <span class="info-box-number">  @Model.TotalProcessing</span>
                                    </div>
                                    <!-- /.info-box-content -->
                                </div>
                                <!-- /.info-box -->
                            </div>
                            <!-- /.col -->
                            <!-- fix for small devices only -->
                            <div class="clearfix hidden-md-up"></div>
                            <div class="col-12 col-sm-6 col-md-3">
                                <div class="info-box mb-3">
                                    <span class="info-box-icon bg-success elevation-1">
                                        <i class="fas fa-shopping-cart"></i>
                                    </span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">@L("Completed")</span>
                                        <span class="info-box-number">@Model.TotalCompleted</span>
                                    </div>
                                    <!-- /.info-box-content -->
                                </div>
                                <!-- /.info-box -->
                            </div>
                            <!-- /.col -->
                            <div class="col-12 col-sm-6 col-md-3">
                                <div class="info-box mb-3">
                                    <span class="info-box-icon bg-warning elevation-1">
                                        <i class="fas fa-ban"></i>
                                    </span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">@L("Cancel")</span>
                                        <span class="info-box-number">@Model.TotalCancel</span>
                                    </div>
                                    <!-- /.info-box-content -->
                                </div>
                                <!-- /.info-box -->
                            </div>
                            <!-- /.col -->
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="OrdersTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>@L("OrderDate")</th>
                                        <th>@L("OrderNumber")</th>
                                        <th>@L("Customer")</th>
                                        <th>@L("OrderType")</th>
                                        <th>@L("Status")</th>
                                        <th style="width: 150px">@L("Actions")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
