@using pbt.ApplicationUtils

<div class="tab-pane fade active show" id="package-list" role="tabpanel" aria-labelledby="custom-tabs-three-home-tab">

    <div class="">
        <div class="table-responsive">
           @*  <h4>Tổng cân nặng: <span class="package-total-weight"></span> </h4> *@
            <table id="PackageTable" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th> </th>
                        <th>@L("Customer")</th>
                        <th>@L("WaybillNumber")</th>
                        @* <th>@L("TotalPackage")</th> *@
                        <th>@L("ExportDate")</th>
                        <th>@L("ImportDate")</th>
                        <th>@L("BagNumber")</th>
                        <th>@L("Weight")</th>
                        <th>@L("Volume")</th>
                        <th>@L("ShippingPartner")</th>
                        <th>Phí VC QT</th>
                        <th>@L("DomesticShippingFee")</th>
                        <th>@L("WoodenPackagingFee")</th>
                        <th>@L("ShockproofFee")</th>
                        <th>@L("InsuranceFee")</th>
                        <th>Tổng chi phí</th>
                        <th>@L("ShippingLine")</th>
                        <th>@L("Note")</th>
                        <th>@L("PackageNumber")</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

</div>