            <div class="col-sm-12">
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item">
                        <a class="nav-link nav-package active" data-type="all" href="#">Tất cả</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-package" href="#" data-type="shipment">Nạp tiền</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-package" data-type="deleted" href="#">Thanh toán</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-package" data-type="fail" href="#">Rút tiền</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-package" data-type="non-pack" href="#">Khiếu nại hoàn tiền</a>
                    </li>

                </ul>
            </div>
        </div>
    </div>
</section>
