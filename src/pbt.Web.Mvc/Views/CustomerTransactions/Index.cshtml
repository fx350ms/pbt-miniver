@using pbt.Web.Startup

@{
    ViewBag.Title = L("CustomerTransactions");
    ViewBag.CurrentPageName = PageNames.Packages;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/CustomerTransactions/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/CustomerTransactions/Index.min.js" asp-append-version="true"></script>
    </environment>
}
