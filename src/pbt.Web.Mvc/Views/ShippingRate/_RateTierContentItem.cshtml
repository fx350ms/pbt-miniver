@using pbt.Web.Models.ShippingRate

@model RateTierContentItemModel

<div class="rate-item" data-line="@Model.LineNumber" data-from="@Model.FromWarehouseId" data-to="@Model.ToWarehouseId">
    <input type="hidden" name="LineNumber" value="@Model.LineNumber" />
    <input type="hidden" name="FromWarehouseId" value="@Model.FromWarehouseId" />
    <input type="hidden" name="ToWarehouseId" value="@Model.ToWarehouseId" />

    <div class="form-row mb-3">
        <div class="col">
            Loại vận chuyển: <label>@Model.LineName</label>
        </div>
        <div class="col">
            Từ: <label>@Model.FromWarehouseName</label>
        </div>
        <div class="col">
            Đến: <label>@Model.ToWarehouseName</label>
        </div>
    </div>

    <!-- Bảng cấu hình giá -->
    <table class="table table-bordered table-hover text-center">
        <thead class="bg-light">
            <tr>
                <th>Phân loại</th>
                <th>Từ</th>
                <th>Đến</th>
                <th width="125">Đơn vị tính</th>
                <th>Đơn giá</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.LineNumber == (int)pbt.ApplicationUtils.CustomerLine.Line2)
            {
                <tr row-data-id="1">
                    <td row-data-id="1">
                        <input type="hidden" name="ProductGroupId" value="1" />
                        <strong>Chung</strong>
                    </td>
                    <td><input type="number" class="form-control" name="FromValue" value="0" /></td>
                    <td><input type="number" class="form-control" name="ToValue" value="999999" /></td>
                    <td>
                        <select class="form-control">
                            <option value="KG">KG</option>
                            <option value="M3">M3</option>
                        </select>
                    </td>
                    <td><input type="text" class="form-control mask-num-price" name="PricePerUnit" value="0" /></td>
                    <td><button class="btn btn-success btn-sm add-tier-row" title="Thêm hàng">+</button></td>
                </tr>
            }
            else
            {
                foreach (var productGroup in Model.ProductGroupTypes)
                {
                    <tr row-data-id="@productGroup.Id">
                        <td row-data-id="@productGroup.Id">
                            <input type="hidden" name="ProductGroupId" value="@productGroup.Id" />
                            <strong> @productGroup.Name</strong>
                        </td>
                        <td><input type="number" class="form-control" name="FromValue" value="0" /></td>
                        <td><input type="number" class="form-control" name="ToValue" value="999999" /></td>
                        <td>
                            <select class="form-control">
                                <option value="KG">KG</option>
                                <option value="M3">M3</option>
                            </select>
                        </td>
                        <td><input type="text" class="form-control mask-num-price" name="PricePerUnit" value="0" /></td>
                        <td><button class="btn btn-success btn-sm add-tier-row" title="Thêm hàng">+</button></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>