@using pbt.Web.Startup
@using pbt.ShippingRates.Dto
@using pbt.Web.Models.Common.Modals

@{
    ViewBag.Title = L("ShippingRates");
    ViewBag.CurrentPageName = PageNames.ShippingRate;
}
@section styles {
    <style>
        .select2-selection--single {
            height: 38px !important;
        }

        .select2-selection__arrow {
            top: 5px !important;
        }

        .select2-container {
            z-index: 99999;
            min-width: 350px;
        }

        .select2.select2-container{
            max-height: 60vh;
            overflow-y: auto;
        }

        .select2-container--default .select2-selection--multiple .select2-selection__choice {
            background-color: #001fff;
        }

    </style>
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/ShippingRates/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/ShippingRates/Index.min.js" asp-append-version="true"></script>
    </environment>
}

 
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("ShippingRates")</h1>
            </div>
            <div class="col-sm-6">
                
                <a href="javascript:;" data-toggle="modal" data-target="#ShippingRateCreateModal" class="btn bg-blue float-sm-right">
                    <i class="fa fa-plus-square"></i>
                    @L("CreateNew")
                </a>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                           
                            <div class="col-md-12">
                                @await Html.PartialAsync("~/Views/ShippingRate/Index.AdvancedSearch.cshtml")
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="ShippingRatesTable" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>@L("STT")</th>
                                        <th>@L("Id")</th>
                                        <th>@L("Name")</th>
                                        <th>@L("IsActived")</th>
                                        <th>@L("IsDefaultForCustomer")</th>
                                        <th>@L("Note")</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/ShippingRate/_CreateModal.cshtml", new ShippingRateGroupDto() { })

<div class="modal fade" id="ShippingRateEditModal" tabindex="-1" role="dialog" aria-labelledby="ShippingRateEditModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content" >
           
        </div>
    </div>
</div>

<div class="modal fade " id="ShippingRateAssignCustomersModal" tabindex="-1" role="dialog" aria-labelledby="ShippingRateAssignCustomersModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@L("AssignCustomersToShippingRate")</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <form id="assignCustomerForm" class="form-horizontal">
                    <input type="hidden" id="ShippingRateGroupId" name="ShippingRateGroupId"   />
                    <select class="select2 form-control select-customer-ids" multiple name="select-customer-ids">
                        @if (ViewBag.Customers != null && ViewBag.Customers.Count > 0)
                        {
                            foreach (var customer in ViewBag.Customers)
                            {
                                <option value="@customer.id">@customer.text</option>
                            }
                        }
                    </select>

                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">@L("Cancel")</button>
                <button type="button" class="btn btn-primary save-customer-button">@L("Save")</button>
            </div>

        </div>
    </div>
</div>