@using Microsoft.AspNetCore.Mvc.TagHelpers
@using pbt.Web.Models.Common.Modals
@using pbt.ShippingRates.Dto

@model ShippingRateGroupDto

@{
    Layout = null;
}

<div class="modal fade" id="ShippingRateCreateModal" tabindex="-1" role="dialog" aria-labelledby="ShippingRateGroupCreateOrEditModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            @await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(Model.Id == 0 ? L("CreateNewShippingRateGroup") : L("EditShippingRateGroup")))
            <form id="ShippingRateGroupForm" role="form" class="form-horizontal">
                <div class="modal-body">
                    <div class="form-group row required">
                        <label class="col-md-3 col-form-label">@L("Name")</label>
                        <div class="col-md-9">
                            <input type="text" class="form-control" name="Name" asp-for="Name" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-md-3 col-form-label">@L("Note")</label>
                        <div class="col-md-9">
                            <textarea class="form-control" name="Note" asp-for="Note"></textarea>
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-md-3 col-form-label">@L("IsActived")</label>
                        <div class="col-md-9">
                            <input type="checkbox" class="form-check-input" name="IsActived" asp-for="IsActived" />
                            <span asp-validation-for="IsActived" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-md-3 col-form-label">@L("IsDefaultForCustomer")</label>
                        <div class="col-md-9">
                            <input type="checkbox" class="form-check-input" name="IsDefaultForCustomer" asp-for="IsDefaultForCustomer" />
                            <span asp-validation-for="IsDefaultForCustomer" class="text-danger"></span>
                        </div>
                    </div>
                     @* <div class="form-group row"></div>
                        <label class="col-md-3 col-form-label">@L("Attachment")</label>
                        <div class="col-md-9">
                            <input type="File" class="form-check-input" name="File"  />
                           
                        </div>
                    </div> *@
                </div>
                @await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
            </form>
        </div>
    </div>
</div>