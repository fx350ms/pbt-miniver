<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<location path="." inheritInChildApplications="false">
		<system.webServer>
			<handlers>
				<add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
				<remove name="WebDAV" />
			</handlers>
			<aspNetCore processPath="dotnet" arguments=".\pbt.Web.Mvc.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
		</system.webServer>
	</location>
	<system.webServer>
		<security>
			<requestFiltering>
				<verbs>
					<add verb="DELETE" allowed="true" />
				</verbs>
			</requestFiltering>
		</security>
	</system.webServer>
</configuration>
